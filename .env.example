# SUPABASE: Connection details for Supabase.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# CLOUDINARY: Cloudinary configuration for image storage.
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
VITE_CLOUDINARY_UPLOAD_PRESET="luxe_and_co"
VITE_CLOUDINARY_CLOUD_NAME="dznwuewea"

# JWT: Secret for signing authentication tokens.
JWT_SECRET="your_jwt_secret_key"
VITE_JWT_SECRET="your_jwt_secret_key"

# WHATSAPP: CallMeBot configuration for notifications.
WHATSAPP_PHONE="your_phone_number"
WHATSAPP_APIKEY="your_callmebot_apikey"

# TELEGRAM: Optional Telegram bot for notifications.
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_CHAT_ID="your_chat_id"
